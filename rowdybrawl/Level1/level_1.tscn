[sub_resource type="GDScript" id="GDScript_kvwx4"]
resource_name = "MeterBar"
script/source = "extends ColorRect

func _ready() -> void:
	GameGlobals.ult_meter_changed.connect(_on_ult_meter_changed)
	

func _on_ult_meter_changed(ult_meter: float):
	$GrayBar/BlueBar/Label.text = \"%.0f%%\" % (ult_meter * 100)
	$GrayBar/BlueBar.size.x = 200 * ult_meter
"

