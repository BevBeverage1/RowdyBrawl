[sub_resource type="GDScript" id="GDScript_fqvtk"]
resource_name = "HealthBar"
script/source = "extends ColorRect

func _ready() -> void:
	GameGlobals.player_hit.connect(_on_player_hit)
	

func _on_player_hit(player_health: float):
	$GrayBar/GreenBar/Label.text = \"%d\" % player_health
	$GrayBar/GreenBar.size.x = 2 * player_health
"

